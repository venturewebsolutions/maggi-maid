---
import ContactSection from '../../components/ContactSection.astro'
import TestimonialsSection from '../../components/TestimonialsSection.astro'
import Layout from '../../layouts/Layout.astro'
import Button from '../../components/Button.astro'
import ArrowRight from '../../components/ArrowRight.astro'

interface Props {
  title: string
}

const { title } = Astro.props
---

<Layout title={title}>
  <div id="hero" class="section">
    <div class="container">
      <div class="hero-columns">
        <div class="hero-column-a">
          <div class="hero-image-wrapper has-dots-before has-dots-after">
            <slot name="hero-image" />
          </div>
        </div>

        <div class="hero-column-b">
          <h1 class="h1 heading has-underline">
            <slot name="heading" />
          </h1>

          <div class="hero-content">
            <slot name="hero-content" />
          </div>

          <Button variant="primary" class="hero-cta" is:link href="/contact/">
            <span>Get In Touch</span>
            <ArrowRight />
          </Button>
        </div>
      </div>
    </div>
  </div>

  <div class="services">
    <slot name="services" />
  </div>

  <TestimonialsSection />
  <ContactSection class="contact-section" />
</Layout>

<style class="scss">
  #hero {
    background-color: var(--colour-primary);
    padding-bottom: 0;
  }

  .hero-column-a {
    display: none;
  }

  .topper {
    font-style: italic;
    color: rgba(var(--rgb-colour-text-base), 0.66);
  }

  .heading {
    padding-bottom: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 1.75rem;
    font-size: 2.25rem;
  }

  .hero-cta {
    margin-top: 1.5rem;
  }

  .contact-section {
    padding-top: 0;
  }

  @media only screen and (min-width: 38rem) {
    .hero-columns {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 3rem;
    }

    .hero-column-a {
      display: block;
      text-align: center;
    }

    .hero-image-wrapper {
      max-width: 18rem;
    }

    .hero-image-wrapper :global(img) {
      border-radius: 9999px;
    }

    .services
      :global(.service-section):nth-child(2n)
      :global(.service-content) {
      order: 2;
    }
  }

  @media only screen and (min-width: 68rem) {
    .hero-columns {
      gap: 5rem;
    }

    .hero-column-b {
      padding-top: 3rem;
    }
  }
</style>
