---
import { Image } from 'astro:assets'
import StarIcon from './StarIcon.astro'
import OpeningQuoteIcon from './OpeningQuoteIcon.astro'
import ClosingQuoteIcon from './ClosingQuoteIcon.astro'
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<'section'> {}

const { class: _, ...props } = Astro.props
---

<section
  {...props}
  id="testimonials"
  class:list={[Astro.props.class, 'section']}
>
  <div class="container">
    <div class="card-wrapper">
      <div class="card">
        <OpeningQuoteIcon aria-hidden="true" class="opening-quote" />
        <ClosingQuoteIcon aria-hidden="true" class="closing-quote" />

        <h2 class="h2 heading has-underline">What People Say About Me</h2>

        <div class="review">
          <div>
            <Image
              src={import('../assets/images/testimonial-photo.jpg')}
              alt="A senior dancing at a social event."
              widths={[316 * 1.75, 415 * 2, 528, 528 * 2]}
              sizes="(min-width: 32rem) calc(50vw - 1rem - 2rem - 2rem/2), calc(100vw - 2rem - 4rem)"
              class="review-photo"
            />
          </div>

          <div class="review-content">
            <p class="review-paragraph">
              &ldquo;We were really worried when Mum started forgetting things
              in the early stages of Alzheimer's. Finding someone we could trust
              was so important to us.
            </p>
            <p>
              Margaret has been a blessing—kind, patient, and incredibly
              reliable. It gives me such peace of mind, especially when I have
              to go to work, knowing someone is there to keep Mum company and
              gently encourage her to stay active. She's wonderful, and I fully
              recommend her without any doubt!&rdquo;.
            </p>
            <div class="review-footer">
              <div class="review-rating">
                {[...Array(5)].map(() => <StarIcon />)}
              </div>
              <p class="review-author">Martha G.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .card {
    background-color: var(--colour-surface);
    padding: 3rem 2rem;
    border-radius: 1rem;
    box-shadow: 0px 4px 11px 0px rgba(0, 0, 0, 0.25);
    position: relative;
  }

  .opening-quote,
  .closing-quote {
    display: none;
  }

  .heading {
    font-size: 1.75rem;
    padding-bottom: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 2.25rem;
    text-align: center;

    &::after {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  .review {
    display: grid;
  }

  .review-photo {
    border-radius: 20px;
    aspect-ratio: 16/9;
    object-fit: cover;
    object-position: top;
  }

  .review-content {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: justify;
  }

  .review-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .review-rating {
    color: var(--colour-accent);
    display: flex;
    gap: 0.25rem;
  }

  .review-author {
    font-weight: 700;
    font-family: var(--font-family-headings);
  }

  @media only screen and (min-width: 32rem) {
    .review {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .review-content {
      margin-top: 0;
      align-self: center;
    }

    .review-photo {
      aspect-ratio: 492/426;
    }
  }

  @media only screen and (min-width: 86rem) {
    .card-wrapper {
      padding-block: 41px;
    }

    .opening-quote,
    .closing-quote {
      display: block;
      position: absolute;
      color: #9da5a0;
    }

    .opening-quote {
      top: 0;
      left: 0;
      transform: translate(-30%, -50%);
    }

    .closing-quote {
      bottom: 0;
      right: 0;
      transform: translate(30%, 50%);
    }
  }
</style>
