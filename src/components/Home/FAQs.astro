---
import { url } from '../../utils'
import ArrowRight from '../ArrowRight.astro'
import FAQ from '../FAQ.astro'

const faqs = [
  {
    question: 'What tasks can you help with?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
  {
    question: 'What if my loved one needs more advanced care?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
  {
    question: 'Are you DBS checked and insured?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
  {
    question: 'What are your rates and minimum booking?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
  {
    question: 'What areas do you cover?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
]
---

<section id="faqs" class="section">
  <div class="container">
    <p class="topper">FAQs</p>
    <h2 class="h2 heading has-underline">Do You Have Any Questions?</h2>

    <div class="faq-list">
      {
        faqs.map((faq, index) => (
          <FAQ
            tag="h4"
            question={faq.question}
            answer={faq.answer}
            is:open={index === 0}
          />
        ))
      }
    </div>

    <a href={url('/about/')} class="link">
      <span>Read All of Our FAQs</span>
      <ArrowRight />
    </a>
  </div>
</section>

<style lang="scss">
  #faqs {
    background-color: var(--colour-primary);
  }

  .topper {
    font-style: italic;
    color: rgba(var(--rgb-colour-text-base), 0.66);
  }

  .heading {
    font-size: 1.75rem;
    padding-bottom: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--colour-accent);
    font-weight: 600;
    transition: color 300ms ease;
    margin-top: 2rem;

    &:hover {
      color: rgba(var(--rgb-colour-accent), 0.75);
    }

    &:active {
      color: rgba(var(--rgb-colour-accent), 0.5);
    }
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
