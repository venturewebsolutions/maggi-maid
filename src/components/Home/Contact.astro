---
import Button from '../Button.astro'
import WhatsAppIcon from '../WhatsAppIcon.astro'

const steps = [
  {
    number: '1',
    heading: 'Reach Out',
    body: 'Call, text, or fill out the contact form below. I respond to all messages within 1 business day— no waiting weeks for an answer.',
  },
  {
    number: '2',
    heading: 'Free, No-Pressure Chat',
    body: "We'll talk about your needs and how I can help. No scripts, no sales pitch — just honest advice tailored to you.",
  },
  {
    number: '3',
    heading: 'Book Your First Visit',
    body: "Once we've agreed on a plan, we'll schedule a day to begin. (Minimum 2-hour visits to ensure meaningful support.)",
  },
]
---

<section id="contact" class="section">
  <div class="container">
    <p class="topper">Contact Me</p>
    <h2 class="h2 heading has-underline">Get In Touch!</h2>

    <div class="steps">
      {
        steps.map((step) => (
          <div class="step">
            <p class="step-number">{step.number}</p>
            <p class="step-heading">{step.heading}</p>
            <p class="step-body">{step.body}</p>
          </div>
        ))
      }
    </div>

    <form action="" method="post" class="form">
      <p class="h2 form-heading has-underline">
        <span class="italic">Ready</span> To Get Started?
      </p>

      <div class="form-group">
        <label for="name" class="form-label">What's your name?</label>
        <input type="text" name="name" id="name" class="form-field" />
      </div>

      <div class="form-group">
        <label for="number" class="form-label">What's your phone number?</label>
        <input type="tel" name="number" id="number" class="form-field" />
        <p class="form-help-text">I'll give you a call back on this number.</p>
      </div>

      <div class="form-group">
        <label for="message" class="form-label">How can I help?</label>
        <textarea name="message" id="message" class="form-field" rows="3"
        ></textarea>
      </div>

      <Button variant="tertiary" type="submit" class="form-submit-btn">
        Let's get started!
      </Button>

      <p class="form-text">
        or connect with me directly by phone, SMS, or WhatsApp
      </p>

      <Button
        variant="quaternary"
        class="form-contact-btn"
        is:link
        href="https://wa.me/+447312189652"
      >
        <WhatsAppIcon class="btn-icon" />
        <span>07312 189 652</span>
      </Button>
    </form>
  </div>
</section>

<style lang="scss">
  #contact {
    background:
      url('../../assets/images/contact-background.svg') top left/1440px 50px
        repeat,
      linear-gradient(var(--colour-primary), var(--colour-primary));
  }

  .topper {
    font-style: italic;
    color: rgba(var(--rgb-colour-text-base), 0.66);
  }

  .heading {
    font-size: 1.75rem;
    padding-bottom: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .steps {
    display: none;
  }

  .step {
    --step-padding: 2rem;
    --step-number-font-size: 6.375rem;

    background-color: #f8f9f7;
    border-radius: 100px;
    padding: var(--step-padding);
    position: relative;
    margin-top: calc(var(--step-number-font-size) / 2);
    box-shadow: 0px 4px 31px 0px rgba(0, 0, 0, 0.25);
  }

  .step-number {
    text-align: center;
    color: #a5aca6;
    font-size: var(--step-number-font-size);
    font-family: var(--font-family-headings);
    line-height: 1;
    margin-top: calc(
      -1 * var(--step-padding) - var(--step-number-font-size) / 2
    );
  }

  .step-heading {
    text-align: center;
    font-weight: 700;
    font-family: var(--font-family-headings);
    font-size: 1.125rem;
  }

  .step-body {
    text-align: justify;
    margin-top: 0.5rem;
  }

  .form {
    background-color: var(--colour-secondary);
    color: var(--colour-primary);
    border-radius: 1rem;
    padding: 2rem 1rem;
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-heading {
    font-size: 1.75rem;
    padding-bottom: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .italic {
    font-style: italic;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-heading .italic {
    margin-right: 0.375rem;
  }

  .form-field {
    display: block;
    background-color: var(--colour-primary);
    color: var(--colour-text-base);
    border-radius: 10px;
    width: 100%;
    padding: 0.5rem 1rem;
    resize: vertical;
  }

  .form-help-text {
    font-style: italic;
    color: rgba(var(--rgb-colour-primary), 0.8);
    font-size: 0.875rem;
  }

  .form-submit-btn {
    margin-top: 0.5rem;
  }

  .form-text {
    font-style: italic;
    text-align: center;
    max-width: 25rem;
    margin-inline: auto;
    margin-block: 0.125rem;
  }

  .form-contact-btn {
    width: 100%;
    max-width: 25rem;
    margin-inline: auto;
  }

  .btn-icon {
    height: 1.5rem;
    width: auto;
    margin-right: 0.25rem;
  }

  @media only screen and (min-width: 64rem) {
    .steps {
      display: grid;
      gap: 2rem;
      grid-template-columns: repeat(3, 1fr);
    }

    .form {
      padding: 3rem 4rem;
      border-radius: 100px;
    }

    .form-help-text {
      font-size: var(--font-size-base);
    }
  }
</style>
