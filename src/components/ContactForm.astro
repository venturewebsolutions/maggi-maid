---
import type { HTMLAttributes } from 'astro/types'
import Button from './Button.astro'
import WhatsAppIcon from './WhatsAppIcon.astro'

interface Props extends HTMLAttributes<'form'> {
  'show:heading'?: boolean
}

const { 'show:heading': showHeading = false, class: _, ...props } = Astro.props
---

<form
  {...props}
  method="POST"
  class:list={[Astro.props.class, 'form']}
  data-netlify="true"
  name="contact"
>
  {
    showHeading && (
      <p class="h2 form-heading has-underline">
        <span class="italic">Ready</span> To Get Started?
      </p>
    )
  }

  <div class="form-group">
    <label for="name" class="form-label">What's your name?</label>
    <input type="text" name="name" id="name" class="form-field" required />
  </div>

  <div class="form-group">
    <label for="number" class="form-label">What's your phone number?</label>
    <input type="tel" name="number" id="number" class="form-field" required />
    <p class="form-help-text">I'll give you a call back on this number.</p>
  </div>

  <div class="form-group">
    <label for="message" class="form-label">How can I help?</label>
    <textarea name="message" id="message" class="form-field" rows="3" required
    ></textarea>
  </div>

  <Button variant="tertiary" type="submit" class="form-submit-btn">
    Let's get started!
  </Button>

  <p class="form-text">
    or connect with me directly by phone, SMS, or WhatsApp
  </p>

  <Button
    variant="quaternary"
    class="form-contact-btn"
    is:link
    href="https://wa.me/+447312189652"
  >
    <WhatsAppIcon class="btn-icon" />
    <span>07312 189 652</span>
  </Button>
</form>

<style lang="scss">
  .form {
    background-color: var(--colour-secondary);
    color: var(--colour-primary);
    border-radius: 50px;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-heading {
    font-size: 1.75rem;
    padding-bottom: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .italic {
    font-style: italic;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-heading .italic {
    margin-right: 0.375rem;
  }

  .form-field {
    display: block;
    background-color: var(--colour-primary);
    color: var(--colour-text-base);
    border-radius: 10px;
    width: 100%;
    padding: 0.5rem 1rem;
    resize: vertical;
  }

  .form-help-text {
    font-style: italic;
    font-size: 0.875rem;
  }

  .form-submit-btn {
    margin-top: 0.5rem;
  }

  .form-text {
    font-style: italic;
    text-align: center;
    max-width: 25rem;
    margin-inline: auto;
    margin-block: 0.125rem;
  }

  .form-contact-btn {
    width: 100%;
    max-width: 25rem;
    margin-inline: auto;
  }

  .btn-icon {
    height: 1.5rem;
    width: auto;
    margin-right: 0.25rem;
  }

  @media only screen and (min-width: 64rem) {
    .steps {
      display: grid;
      gap: 2rem;
      grid-template-columns: repeat(3, 1fr);
    }

    .form {
      padding: 4rem 4rem;
      border-radius: 100px;
    }
  }
</style>
