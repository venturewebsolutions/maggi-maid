---
import ContactSection from '../components/ContactSection.astro'
import FAQ from '../components/FAQ.astro'
import FAQList from '../components/FAQList.astro'
import Layout from '../layouts/Layout.astro'

const faqs = [
  {
    question: 'What tasks can you help with?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
  {
    question: 'What if my loved one needs more advanced care?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
  {
    question: 'Are you DBS checked and insured?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
  {
    question: 'What are your rates and minimum booking?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
  {
    question: 'What areas do you cover?',
    answer:
      "I assist with light housekeeping, meal prep, shopping, laundry, transportation to appointments, and companionship. Note: I don't provide personal care (e.g., bathing, dressing, or medication).",
  },
]
---

<Layout title="FAQs">
  <div class="section">
    <div class="container">
      <h1 class="topper">FAQs</h1>
      <h2 class="h2 heading has-underline">Do You Have Any Questions?</h2>

      <FAQList faqs={faqs} tag="h3" />
    </div>
  </div>

  <ContactSection />
</Layout>

<style lang="scss">
  .section {
    background-color: var(--colour-primary);
  }

  .topper {
    font-style: italic;
    font-family: var(--font-family-base);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-base);
    line-height: var(--line-height-base);
    color: rgba(var(--rgb-colour-text-base), 0.66);
  }

  .heading {
    font-size: 1.75rem;
    padding-bottom: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }
</style>
